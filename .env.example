# Environment variables for development
# In production, these would be managed by a secrets manager

# Google Gemini — Required for LLM inference
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Security — CHANGE THIS IN PRODUCTION
JWT_SECRET_KEY=viniyog-rag-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
KB_TOKEN_EXPIRY_MINUTES=1

# Application
DEBUG=true
LOG_LEVEL=INFO

# LLM Configuration
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.1

# Embedding
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Vector Store
VECTOR_STORE_TYPE=chromadb
CHROMA_COLLECTION_NAME=banking_knowledge

# Cross-Encoder Re-ranking (two-stage retrieval)
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=3

# Hallucination Detection (0.85 = strict banking threshold)
HALLUCINATION_THRESHOLD=0.85
HALLUCINATION_CHECK_ENABLED=true

# Retrieval (Top-K=10 initial, narrowed to RERANK_TOP_K by cross-encoder)
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.65
